# ==============================================
# CodPulse — Variables d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# NE JAMAIS committer le fichier .env dans git
# ==============================================

# --- Base de données MySQL ---
DATABASE_URL="mysql://user:password@localhost:3306/warzone_cdl"

# --- JWT ---
JWT_SECRET=votre_cle_secrete_minimum_32_caracteres_ici
JWT_EXPIRES_IN=7d

# --- Serveur ---
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Scraper ---
SCRAPE_INTERVAL_MINUTES=60
SCRAPE_ENABLED=true

# --- Compte admin initial (seed) ---
ADMIN_EMAIL=admin@cod-pulse.fr
ADMIN_PASSWORD=MotDePasseSecurise123!

# --- Twitch API (page Live) ---
# Créer une app sur https://dev.twitch.tv/console
TWITCH_CLIENT_ID=votre_client_id_twitch
TWITCH_CLIENT_SECRET=votre_client_secret_twitch

# --- Tracker.gg API (Top 250) ---
# Obtenir une clé sur https://tracker.gg/developers/apps
TRN_API_KEY=votre_cle_api_tracker_gg
